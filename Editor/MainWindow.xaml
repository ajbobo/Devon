<Window x:Class="Devon.Editor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Devon.Editor.ViewModels"
        xmlns:conv="clr-namespace:Devon.Editor.Converters"
        mc:Ignorable="d"
        Title="Devon Room Editor" Height="700" Width="1000">
    <Window.Resources>
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
        <conv:NullOrEmptyToVisibilityConverter x:Key="NullOrEmptyToVisibilityConverter"/>
        <conv:ActionTypeToTargetVisibilityConverter x:Key="ActionTypeToTargetVisibilityConverter"/>
    </Window.Resources>
    <Window.DataContext>
        <vm:MainWindowViewModel/>
    </Window.DataContext>
    <DockPanel Margin="5">
        <ToolBar DockPanel.Dock="Top">
            <Button Content="Load" Command="{Binding LoadRoomsCommand}" Margin="0,0,5,0" Padding="10,5"/>
            <Button Content="Save All" Command="{Binding SaveAllCommand}" Margin="0,0,5,0" Padding="10,5"/>
            <Separator/>
            <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" FontWeight="SemiBold"/>
        </ToolBar>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Room list -->
            <Border Grid.Column="0" BorderBrush="LightGray" BorderThickness="1" Margin="0,0,5,0">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5">
                        <Button Content="New" Command="{Binding NewRoomCommand}" Margin="0,0,5,0" Padding="15,5"/>
                        <Button Content="Delete" Command="{Binding DeleteRoomCommand}" Padding="15,5"/>
                    </StackPanel>
                    <ListBox ItemsSource="{Binding Rooms}"
                             SelectedItem="{Binding SelectedRoom}"
                             DisplayMemberPath="Name"
                             Margin="5"
                             VerticalContentAlignment="Center">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right panel: Editor -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel DataContext="{Binding Editor}" Margin="10">
                    <!-- Show message when no room selected -->
                    <TextBlock Text="Select a room to edit or create a new one."
                               FontStyle="Italic"
                               Foreground="Gray"
                               Visibility="{Binding Editor, Converter={StaticResource NullToVisibilityConverter}}"/>

                    <StackPanel Visibility="{Binding Editor, Converter={StaticResource NotNullToVisibilityConverter}}">
                        <!-- Room Name -->
                        <TextBlock Text="Room Name:" FontWeight="Bold"/>
                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,5,0,10"/>

                        <!-- Descriptions -->
                        <TextBlock Text="Descriptions:" FontWeight="Bold" Margin="0,10,0,0"/>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,5,0,0">
                            <ListBox ItemsSource="{Binding Descriptions}"
                                     SelectedItem="{Binding SelectedDescription, Mode=TwoWay}"
                                     Height="100">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="5">
                                            <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold" TextWrapping="Wrap" BorderThickness="0" Background="Transparent"/>
                                            <TextBox Text="{Binding Condition, UpdateSourceTrigger=PropertyChanged}" FontStyle="Italic" Foreground="Gray" TextWrapping="Wrap" BorderThickness="0" Background="Transparent"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Content="Add Description" Command="{Binding DataContext.AddDescriptionCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,5,0"/>
                            <Button Content="Remove" Command="{Binding DataContext.RemoveDescriptionCommand, RelativeSource={RelativeSource AncestorType=Window}}" Padding="10,5"/>
                        </StackPanel>

                        <!-- Conditions -->
                        <TextBlock Text="Conditions:" FontWeight="Bold" Margin="0,10,0,0"/>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,5,0,0">
                            <ListBox ItemsSource="{Binding Conditions}"
                                     SelectedItem="{Binding SelectedCondition, Mode=TwoWay}"
                                     Height="60">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" BorderThickness="0" Background="Transparent"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Content="Add Condition" Command="{Binding DataContext.AddConditionCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,5,0"/>
                            <Button Content="Remove" Command="{Binding DataContext.RemoveConditionCommand, RelativeSource={RelativeSource AncestorType=Window}}" Padding="10,5"/>
                        </StackPanel>

                        <!-- Actions -->
                        <TextBlock Text="Actions:" FontWeight="Bold" Margin="0,10,0,0"/>
                        <Border BorderBrush="LightGray" BorderThickness="1" Margin="0,5,0,0">
                            <ListBox ItemsSource="{Binding Actions}"
                                     SelectedItem="{Binding SelectedAction, Mode=TwoWay}"
                                     Height="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Key}" FontWeight="Bold" Width="80"/>
                                            <TextBlock Text=" - "/>
                                            <TextBlock Text="{Binding Type}" Foreground="DarkBlue"/>
                                            <TextBlock Text="  "/>
                                            <TextBlock Text="{Binding TargetRoom}" FontStyle="Italic" Foreground="Gray" Visibility="{Binding Type, Converter={StaticResource ActionTypeToTargetVisibilityConverter}}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Border>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Button Content="Add Action" Command="{Binding DataContext.AddActionCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,5,0"/>
                            <Button Content="Remove Action" Command="{Binding DataContext.RemoveActionCommand, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,0,5,0" Padding="10,5"/>
                        </StackPanel>

                        <!-- Action Detail Editor -->
                        <Border Visibility="{Binding SelectedAction, Converter={StaticResource NotNullToVisibilityConverter}}"
                                BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Edit Action" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Key:" Grid.Row="0" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="0" Grid.Column="1"
                                          ItemsSource="{Binding SelectedAction.ValidKeys}"
                                          SelectedItem="{Binding SelectedAction.Key, Mode=TwoWay}"
                                          Margin="0,0,0,5"/>

                                <TextBlock Text="Type:" Grid.Row="1" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <ComboBox Grid.Row="1" Grid.Column="1" SelectedItem="{Binding SelectedAction.Type}" Margin="0,0,0,5" IsEnabled="False">
                                    <ComboBox.Items>
                                        <vm:RoomActionEntryType>Exit</vm:RoomActionEntryType>
                                        <vm:RoomActionEntryType>Take</vm:RoomActionEntryType>
                                        <vm:RoomActionEntryType>Use</vm:RoomActionEntryType>
                                        <vm:RoomActionEntryType>Talk</vm:RoomActionEntryType>
                                    </ComboBox.Items>
                                </ComboBox>

                                <TextBlock Text="Target Room:" Grid.Row="2" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding SelectedAction.TargetRoom}" Margin="0,0,0,5"/>

                                <TextBlock Text="Item:" Grid.Row="3" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding SelectedAction.Item}" Margin="0,0,0,5"/>

                                <TextBlock Text="Target:" Grid.Row="4" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding SelectedAction.Target}" Margin="0,0,0,5"/>

                                <TextBlock Text="Says:" Grid.Row="5" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding SelectedAction.Says}" Margin="0,0,0,5"/>

                                <TextBlock Text="Result Text:" Grid.Row="6" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding SelectedAction.ResultText}" Margin="0,0,0,5"/>

                                <TextBlock Text="Action Commands:" Grid.Row="7" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding SelectedAction.ActionCommands}" Margin="0,0,0,5"/>

                                <TextBlock Text="Condition:" Grid.Row="8" Grid.Column="0" Margin="0,0,5,5" VerticalAlignment="Center"/>
                                <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding SelectedAction.Condition}" Margin="0,0,0,5"/>
                            </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Save Changes -->
                        <Button Content="Save Changes" Command="{Binding DataContext.SaveChangesCommand, RelativeSource={RelativeSource AncestorType=Window}}" Padding="20,5" Margin="0,10,0,0"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
